# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Calendar Integration
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
VITE_GOOGLE_API_KEY=your_google_api_key
VITE_PRINCIPAL_CALENDAR_ID=your_calendar_email@gmail.com

# App URL (used for approval links)
VITE_APP_URL=http://localhost:5173

# Telegram Proxy (Edge Function URL — bot token is stored server-side only)
VITE_TELEGRAM_PROXY_URL=https://your-project.supabase.co/functions/v1/telegram-proxy
VITE_TELEGRAM_CHAT_ID=your_chat_id
# Must match TELEGRAM_PROXY_SECRET in Supabase Edge Function secrets (leave blank if not set)
VITE_TELEGRAM_PROXY_SECRET=your_proxy_secret_here
